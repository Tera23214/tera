#!/usr/bin/env wolframscript

ClearAll[
  optionValue,
  normalizeNumberString,
  parseNumber,
  parseInteger,
  parseLambdaValues,
  buildLambdaValues,
  runOneLambda
];

scriptPath = If[StringLength[$InputFileName] > 0, $InputFileName, First[$ScriptCommandLine]];
scriptDir = DirectoryName[scriptPath];
args = Rest[$ScriptCommandLine];

optionValue[argList_List, name_String, default_] := Module[{pos},
  pos = FirstPosition[argList, name, None];
  If[pos === None || pos[[1]] >= Length[argList],
    default,
    argList[[pos[[1]] + 1]]
  ]
];

normalizeNumberString[value_String] := StringReplace[
  value,
  RegularExpression["([0-9.]+)[eE]([+-]?[0-9]+)"] -> "$1*^$2"
];

parseNumber[value_] := N[ToExpression[normalizeNumberString[ToString[value]]]];

parseInteger[value_] := Round[parseNumber[value]];

parseLambdaValues[text_String] := parseNumber /@ Select[
  StringSplit[text, {",", " ", "\t", "\n"}],
  StringLength[#] > 0 &
];

buildLambdaValues[argList_List] := Module[
  {explicit, start, stop, step},
  explicit = optionValue[argList, "--lambdas", ""];
  If[StringLength[explicit] > 0,
    Return[parseLambdaValues[explicit]]
  ];

  start = parseNumber[optionValue[argList, "--lambda-start", "0.5"]];
  stop = parseNumber[optionValue[argList, "--lambda-stop", "5.0"]];
  step = parseNumber[optionValue[argList, "--lambda-step", "0.1"]];

  If[step <= 0, Print["--lambda-step must be positive."]; Exit[2]];
  N[Range[start, stop + step/2, step]]
];

If[MemberQ[args, "--help"],
  Print["Usage:"];
  Print["  wolframscript -file tera/SE_Alternating --lambdas 1,1.5,2,2.5,3"];
  Print["  wolframscript -file tera/SE_Alternating --lambda-start 0.5 --lambda-stop 5 --lambda-step 0.1"];
  Print["Options:"];
  Print["  --N1 INT --N2 INT --alpha-w FLOAT --a FLOAT"];
  Print["  --tol FLOAT --max-iter INT --eps FLOAT --output PATH"];
  Print["Output:"];
  Print["  lambda m_w m_x m_y, where m_y = m_w m_x"];
  Exit[0]
];

config = <|
  "N1" -> parseInteger[optionValue[args, "--N1", "4000"]],
  "N2" -> parseInteger[optionValue[args, "--N2", "3000"]],
  "alphaW" -> parseNumber[optionValue[args, "--alpha-w", "1.6"]],
  "a" -> parseNumber[optionValue[args, "--a", "0.01"]],
  "tol" -> parseNumber[optionValue[args, "--tol", "1e-12"]],
  "maxIter" -> parseInteger[optionValue[args, "--max-iter", "1000"]],
  "eps" -> parseNumber[optionValue[args, "--eps", "1"]],
  "output" -> optionValue[args, "--output", FileNameJoin[{scriptDir, "SE_alternating_results.dat"}]]
|>;

lambdaValues = buildLambdaValues[args];

runOneLambda[lambda_, cfg_Association] := Module[
  {
    n1 = cfg["N1"],
    n2 = cfg["N2"],
    alphaW = cfg["alphaW"],
    alphaX,
    eps = cfg["eps"],
    tol = cfg["tol"],
    maxIter = cfg["maxIter"],
    mw = cfg["a"],
    mx = cfg["a"],
    t = 0,
    diff = Infinity,
    oldMw,
    oldMx,
    vW,
    vX,
    chiW,
    chiX,
    mwProposal,
    mxProposal,
    mwNext,
    mxNext
  },
  alphaX = (n1/n2) alphaW;
  While[t < maxIter && diff > tol,
    oldMw = mw;
    oldMx = mx;

    vW = lambda^2 (1 - oldMw oldMx);
    chiW = 1/(1 + vW);
    mwProposal = alphaW lambda^2 oldMw chiW/(1 + alphaW lambda^2 oldMw chiW);
    mwNext = oldMw + eps (mwProposal - oldMw);

    vX = lambda^2 (1 - mwNext oldMx);
    chiX = 1/(1 + vX);
    mxProposal = alphaX lambda^2 oldMx chiX/(1 + alphaX lambda^2 oldMx chiX);
    mxNext = oldMx + eps (mxProposal - oldMx);

    diff = Max[Abs[mwNext - oldMw], Abs[mxNext - oldMx]];

    mw = mwNext;
    mx = mxNext;
    t++;
  ];

  <|"lambda" -> lambda, "m_w" -> mw, "m_x" -> mx, "m_y" -> mw mx|>
];

results = runOneLambda[#, config] & /@ lambdaValues;
header = {"lambda", "m_w", "m_x", "m_y"};
table = Prepend[(Lookup[#, header] &) /@ results, header];

Export[config["output"], table, "Table"];

Print["Saved: " <> config["output"]];
Print[ExportString[table, "Table"]];
