# =============================================================================
# Git Blacklist Mode: Ignore specific directories, track Wang/ and share/
# =============================================================================

# Directories to ignore (not uploaded to git)
smf/
docs/
scripts/
results/
_legacy/
phase_analysis/
tests/

# Keep Wang/ and share/ (tracked by default)
# Keep README.md, .gitignore, LICENSE (tracked by default)

# Root level files to ignore (private)
CLAUDE.md
HANDOVER.md
*.md
!README.md
pyproject.toml
test_*.md

# =============================================================================
# Python (applies globally)
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
eggs/
.eggs/
*.egg-info/
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/

# =============================================================================
# IDE and Editor
# =============================================================================
.claude/
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# System files
# =============================================================================
.DS_Store
Thumbs.db
*.log
